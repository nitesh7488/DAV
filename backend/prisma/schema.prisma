generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile Student?
  teacherProfile Teacher?
  parentProfile  Parent?
}

model Student {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  admissionNo    String    @unique
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  gender         String
  bloodGroup     String?
  address        String
  classId        String
  class          Class     @relation(fields: [classId], references: [id])
  parentId       String?
  parent         Parent?   @relation(fields: [parentId], references: [id])
  
  attendances    Attendance[]
  feePayments    FeePayment[]
  marks          Mark[]
  bookIssues     BookIssue[]
}

model Teacher {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId     String    @unique
  firstName      String
  lastName       String
  qualification  String
  joiningDate    DateTime
  designation    String
  department     String
  
  classes        Class[]   @relation("ClassTeacher")
  subjects       Subject[]
}

model Parent {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  phoneNumber    String
  occupation     String?
  
  children       Student[]
}

model Class {
  id             String    @id @default(uuid())
  name           String    // e.g., "10"
  section        String    // e.g., "A"
  teacherId      String?
  classTeacher   Teacher?  @relation("ClassTeacher", fields: [teacherId], references: [id])
  
  students       Student[]
  subjects       Subject[]
  timetables     Timetable[]
}

model Subject {
  id             String    @id @default(uuid())
  name           String
  code           String
  classId        String
  class          Class     @relation(fields: [classId], references: [id])
  teacherId      String?
  teacher        Teacher?  @relation(fields: [teacherId], references: [id])
  
  marks          Mark[]
}

model Attendance {
  id             String    @id @default(uuid())
  date           DateTime
  status         String    // PRESENT, ABSENT, HALF_DAY, LATE
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  markedById     String?   // Teacher who marked it
}

model FeePayment {
  id             String    @id @default(uuid())
  amount         Float
  paymentDate    DateTime  @default(now())
  status         String    // PENDING, SUCCESS, FAILED
  method         String    // RAZORPAY, CASH, TRANSFER
  razorpayId     String?
  receiptNo      String    @unique
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  term           String    // e.g., "Term 1", "Annual"
}

model Mark {
  id             String    @id @default(uuid())
  examName       String    // e.g., "Mid Term"
  marksObtained  Float
  totalMarks     Float
  grade          String?
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  subjectId      String
  subject        Subject   @relation(fields: [subjectId], references: [id])
}

model Notice {
  id             String    @id @default(uuid())
  title          String
  content        String
  date           DateTime  @default(now())
  targetRoles    String[]  // Array of roles or "ALL"
  attachmentUrl  String?
  createdById    String
}

// Module 05: Payroll
model Payroll {
  id             String    @id @default(uuid())
  teacherId      String
  month          String    // e.g., "May 2026"
  basicSalary    Float
  allowances     Float
  deductions     Float
  netSalary      Float
  status         String    // PAID, PENDING
  paymentDate    DateTime?
}

// Module 07: Academic (Timetable)
model Timetable {
  id             String    @id @default(uuid())
  classId        String
  class          Class     @relation(fields: [classId], references: [id])
  dayOfWeek      String    // MONDAY, TUESDAY...
  startTime      String    // "08:00 AM"
  endTime        String    // "09:00 AM"
  subjectId      String
  teacherId      String
}

// Module 09: Library
model Book {
  id             String    @id @default(uuid())
  title          String
  author         String
  isbn           String    @unique
  totalCopies    Int
  available      Int
  issues         BookIssue[]
}

model BookIssue {
  id             String    @id @default(uuid())
  bookId         String
  book           Book      @relation(fields: [bookId], references: [id])
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  issueDate      DateTime  @default(now())
  dueDate        DateTime
  returnDate     DateTime?
  fineAmount     Float     @default(0)
  status         String    // ISSUED, RETURNED, LOST
}

// Module 10: Transport
model Vehicle {
  id             String    @id @default(uuid())
  registrationNo String    @unique
  capacity       Int
  driverName     String
  driverPhone    String
  routes         Route[]
}

model Route {
  id             String    @id @default(uuid())
  name           String
  vehicleId      String
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id])
  stops          String[]  // Array of stop names
}

// Module 11: Inventory
model InventoryItem {
  id             String    @id @default(uuid())
  name           String
  category       String
  quantity       Int
  unitPrice      Float
  lastUpdated    DateTime  @updatedAt
}

// Module 12: Account
model Transaction {
  id             String    @id @default(uuid())
  type           String    // INCOME, EXPENSE
  category       String    // e.g., "Fee", "Salary", "Maintenance"
  amount         Float
  date           DateTime  @default(now())
  description    String
  referenceNo    String?
}

// Module 13: Admission Inquiries
model Inquiry {
  id          String   @id @default(uuid())
  studentName String
  parentName  String
  phone       String
  email       String
  grade       String
  location    String?
  visitDate   String?
  message     String?
  status      String   @default("PENDING") // PENDING, CALLED, VISITED, CONFIRMED
  createdAt   DateTime @default(now())
}
